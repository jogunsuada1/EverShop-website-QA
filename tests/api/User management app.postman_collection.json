      "name": "USER",
      "item": [
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.collectionVariables.set(\"user_Id\" , pm.response.json().userId)\r",
                  "\r",
                  "\r",
                  "// Parse the raw body into a JSON object\r",
                  "const body = JSON.parse(pm.request.body.raw);\r",
                  "\r",
                  "// Access the password property\r",
                  "const randpassword = body.password;\r",
                  "\r",
                  "const randrole = body.role\r",
                  "\r",
                  "// Save it to a collection variable\r",
                  "pm.collectionVariables.set(\"pass\", randpassword);\r",
                  "\r",
                  "pm.collectionVariables.set(\"role\", randrole);\r",
                  "\r",
                  "  //tests\r",
                  "\r",
                  "pm.test(\"Status code is 201\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "const createSchema = {\r",
                  "\r",
                  "  \"type\": \"object\",\r",
                  "  \"properties\": {\r",
                  "    \"message\": {\r",
                  "      \"type\": \"string\"\r",
                  "    },\r",
                  "    \"userId\": {\r",
                  "      \"type\": \"string\"\r",
                  "    }\r",
                  "  },\r",
                  "  \"required\": [\r",
                  "    \"message\",\r",
                  "    \"userId\"\r",
                  "  ]\r",
                  "}\r",
                  "\r",
                  "pm.test(\"verify valid schema\" , function () {\r",
                  "    pm.response.to.have.jsonSchema(createSchema)\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.execution.setNextRequest(\"Login\");\r",
                  "\r",
                  "// This runs before EVERY request in the collection\r",
                  "const randomUser = `joseven${Math.floor(Math.random() * 10000)}`;\r",
                  "pm.collectionVariables.set(\"username\", randomUser);\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"username\": \"{{username}}\",\r\n    \"password\": \"{{$randomPassword}}\",\r\n    \"role\": \"{{$randomJobTitle}}\",\r\n    \"firstName\": \"{{$randomFirstName}}\",\r\n    \"lastName\": \"{{$randomLastName}}\",\r\n    \"state\": \"{{$randomCity}}\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
