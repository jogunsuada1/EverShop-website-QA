        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// set auth value\r",
                  "\r",
                  "const response = pm.response.json();\r",
                  "\r",
                  "const loginSchema = {\r",
                  "  \r",
                  "  \"type\": \"object\",\r",
                  "  \"properties\": {\r",
                  "    \"accessToken\": {\r",
                  "      \"type\": \"string\"\r",
                  "    },\r",
                  "    \"expireDurationSeconds\": {\r",
                  "      \"type\": \"number\"\r",
                  "    },\r",
                  "    \"refreshToken\": {\r",
                  "      \"type\": \"string\"\r",
                  "    }\r",
                  "  },\r",
                  "  \"required\": [\r",
                  "    \"accessToken\",\r",
                  "    \"expireDurationSeconds\",\r",
                  "    \"refreshToken\"\r",
                  "  ]\r",
                  "}\r",
                  "\r",
                  "pm.environment.set(\"access_token\", response.accessToken);  \r",
                  "\r",
                  "pm.test(\"Status code is 201\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "\r",
                  "pm.test(\"verify schema\" , function () {\r",
                  "    pm.response.to.have.jsonSchema(loginSchema);\r",
                  "});\r",
                  "\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "packages": {},
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
