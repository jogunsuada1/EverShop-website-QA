        {
          "name": "Delete user",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const jsonData = pm.response.json();\r",
                  "\r",
                  "if (pm.response.code === 200) {\r",
                  "    pm.test(\"Success: User deleted\", function () {\r",
                  "        pm.response.to.have.status(200);\r",
                  "    });\r",
                  "} else {\r",
                  "    // This is your negative test branch\r",
                  "    pm.test(\"Failure: Correct error handling for \" + pm.response.code, function () {\r",
                  "        pm.expect(pm.response.code).to.be.oneOf([401, 403]);\r",
                  "        pm.expect(jsonData.detail).to.eql(\"Unauthorized\");\r",
                  "    });\r",
                  "}"
