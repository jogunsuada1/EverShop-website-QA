        {
          "name": "Get User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "  //verify status code is 200\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "  //verify schema\r",
                  "const schema = {\r",
                  "\r",
                  "  \"type\": \"object\",\r",
                  "  \"properties\": {\r",
                  "    \"username\": {\r",
                  "      \"type\": \"string\"\r",
                  "    },\r",
                  "    \"role\": {\r",
                  "      \"type\": \"string\"\r",
                  "    },\r",
                  "    \"firstName\": {\r",
                  "      \"type\": \"string\"\r",
                  "    },\r",
                  "    \"lastName\": {\r",
                  "      \"type\": \"string\"\r",
                  "    },\r",
                  "    \"state\": {\r",
                  "      \"type\": \"string\"\r",
                  "    }\r",
                  "  },\r",
                  "  \"required\": [\r",
                  "    \"username\",\r",
                  "    \"role\",\r",
                  "    \"firstName\",\r",
                  "    \"lastName\",\r",
                  "    \"state\"\r",
                  "  ]\r",
                  "}\r",
                  "\r",
                  "pm.test(\"verify schema\" , function() {\r",
                  "    pm.response.to.have.jsonSchema(schema)\r",
                  "});\r",
                  "\r",
                  "  //verify user details\r",
                  "// Optional: Check other details like name or email if you saved those too\r",
                  "pm.test(\"User name is correct\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    const savedName = pm.collectionVariables.get(\"user_name\");\r",
                  "    \r",
                  "    if (savedName) {\r",
                  "        pm.expect(jsonData.name).to.eql(savedName);\r",
                  "    }\r",
                  "});\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
